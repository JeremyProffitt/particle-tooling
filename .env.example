# Copy to .env and fill in. .env is gitignored - never commit real credentials.

# Wi-Fi the Photon should join (2.4 GHz only - Photons can't use 5 GHz)
WIFI_SSID=YourNetwork
WIFI_PASSWORD=yourpassword
# NONE | WEP | WPA2_AES | WPA2_TKIP | WPA2_AES+TKIP | WPA_AES | WPA_TKIP | WPA_AES+TKIP
WIFI_SECURITY=WPA2_AES

# Serial port of the device (run `particle serial list` to find it). Required.
COM_PORT=COM26

# Optional. Auto-detected from COM_PORT if left blank.
DEVICE_ID=
# Optional. If set, the device is renamed after a successful claim.
DEVICE_NAME=
# Optional. Set to 1 to skip the Device OS update step without prompting.
SKIP_UPDATE=
