# Copy to .env and fill in. .env is gitignored - never commit real credentials.

# Wi-Fi the Photon should join (2.4 GHz only - Photons can't use 5 GHz)
WIFI_SSID=YourNetwork
WIFI_PASSWORD=yourpassword
# NONE | WEP | WPA2_AES | WPA2_TKIP | WPA2_AES+TKIP | WPA_AES | WPA_TKIP | WPA_AES+TKIP
WIFI_SECURITY=WPA2_AES

# Optional. Leave BLANK to get the device menu (recommended). Set to a 24-hex
# device id to claim just that one device and skip the menu.
DEVICE_ID=
# Optional. If set, a single claimed device is renamed after it comes online.
DEVICE_NAME=
# Optional. Set to 1 so AUTO mode skips the Device OS update phase.
SKIP_UPDATE=
